{
	"name": "Deluge Remote Modern",
	"description": "A modern Manifest V3 fork of Remote Deluge. Quick overview of torrent status for Deluge with dark mode support.",
	"version": "2.0.1",
	"icons": {
		"128": "images/icons/128.png",
		"64": "images/icons/64.png",
		"32": "images/icons/32.png",
		"16": "images/icons/16.png"
	},
	"web_accessible_resources": [
		{
			"resources": [
				"images/icons/16.png",
				"images/icons/16_green.png"
			],
			"matches": ["<all_urls>"]
		}
	],
	"default_locale": "en",
	"background": {
		"service_worker": "js/background.js",
		"type": "module"
	},
	"options_page": "options.html",
	"action": {
		"default_icon": "images/icons/deluge.png",
		"default_title": "__MSG_browser_title_disabled__",
		"default_popup": "popup.html"
	},
	"content_scripts": [
		{
			"matches": [
				"http://*/*",
				"https://*/*"
			],
			"js": [
				"js/libs/jquery-4.0.0.min.js",
				"js/global_options.js",
				"js/debug_log.js",
				"js/add_torrent.js"
			]
		}
	],
	"permissions": [
		"tabs",
		"contextMenus",
		"storage"
	],
	"host_permissions": [
		"http://*/*",
		"https://*/*"
	],
	"manifest_version": 3
}
